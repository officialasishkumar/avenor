# Avenor environment configuration
# Copy to .env and fill in values

# GitHub API token — required for higher rate limits and private repos
AVENOR_GITHUB_TOKEN=

# Database (default: SQLite, use PostgreSQL for production/Docker)
# AVENOR_DATABASE_URL=postgresql+psycopg2://avenor:avenor@localhost:5432/avenor

# Redis (required for Celery background workers)
# AVENOR_REDIS_URL=redis://localhost:6379/0

# Web server
# AVENOR_HOST=127.0.0.1
# AVENOR_PORT=8000

# Data directory (default: .avenor in project root)
# AVENOR_DATA_DIR=/path/to/data
